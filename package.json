{
  "name": "trading-pro-app",
  "version": "1.0.0",
  "description": "Trading Pro — Application desktop pour le suivi de marchés, paper trading, formation et veille blockchain.",
  "main": "dist-electron/main.js",
  "author": {
    "name": "Trading Pro",
    "email": "contact@trading-pro.local"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "package": "npm run build && electron-builder",
    "package:linux": "npm run build && electron-builder --linux AppImage",
    "package:win": "npm run build && electron-builder --win nsis",
    "package:all": "npm run build && electron-builder -mwl",
    "lint": "eslint src electron --ext .ts,.tsx",
    "start": "electron ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.0",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.5.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "i18next": "^26.2.0",
    "jsonwebtoken": "^9.0.2",
    "lightweight-charts": "^4.2.1",
    "lucide-react": "^0.454.0",
    "nodemailer": "^6.9.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.13.3",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.16",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.tradingpro.app",
    "productName": "Trading Pro",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "asar": true,
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Finance",
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
