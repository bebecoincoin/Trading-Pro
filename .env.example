# =========================================================================
# Trading Pro - Variables d'environnement (a renommer en .env)
# =========================================================================
# Ces variables sont utilisees par le processus principal Electron.

# Secret JWT (changez-le imperativement en production)
JWT_SECRET=change-me-please-with-a-very-long-random-string

# SMTP pour la verification d'email (Mailtrap, Gmail App Password, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Trading Pro <noreply@trading-pro.app>"

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:53682/oauth2callback

# APIs gratuites (toutes optionnelles - l'app fonctionne sans cles)
# CoinGecko: gratuit, demo key optionnelle pour rate limits plus eleves
COINGECKO_DEMO_KEY=
# CryptoCompare: gratuit, cle conseillee
CRYPTOCOMPARE_KEY=
# Alpha Vantage (actions US): gratuit avec 25 req/jour
ALPHAVANTAGE_KEY=
# News API (https://newsapi.org): 100 req/jour gratuit
NEWS_API_KEY=

# Supabase (forum + DMs + communaute) - optionnel
# Voir docs/SUPABASE.md pour le setup
SUPABASE_URL=
SUPABASE_ANON_KEY=
